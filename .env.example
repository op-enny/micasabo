# Domain (production: your real domain; local dev: localhost)
DOMAIN=localhost

# A long random secret for signing session cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_64_char_hex_string

# SMTP (for sending contracts and reminders)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=

# S3-compatible backup (Litestream — Phase 4)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
